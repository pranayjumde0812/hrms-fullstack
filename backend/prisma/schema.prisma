generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ----------------------------------------------------
// ENUMS
// ----------------------------------------------------
enum Role {
  SUPER_ADMIN
  HR_MANAGER
  PROJECT_MANAGER
  EMPLOYEE
}

enum EmploymentType {
  FULL_TIME
  PART_TIME
  INTERN
  CONTRACTOR
  CONSULTANT
}

enum EmployeeLifecycleStatus {
  ACTIVE
  PROBATION
  NOTICE
  EXITED
}

enum TimesheetStatus {
  PENDING
  APPROVED
  REJECTED
}

enum WorkMode {
  WFH
  OFFICE
  OTHER
}

enum AttendanceRegularizationType {
  MISSED_CHECK_IN
  MISSED_CHECK_OUT
  FULL_CORRECTION
  WORK_MODE_CORRECTION
}

enum AttendanceRegularizationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum AttendanceSource {
  WEB
  MANUAL_CORRECTION
  REGULARIZATION
  IMPORT
}

enum AttendanceDayStatus {
  PRESENT
  LATE
  HALF_DAY
}

enum AttendanceOvertimeStatus {
  PENDING
  APPROVED
  REJECTED
}

// ----------------------------------------------------
// ENTITIES
// ----------------------------------------------------
model User {
  id             Int         @id @default(autoincrement())
  employeeCode   String?     @unique
  email          String      @unique
  password       String
  firstName      String
  lastName       String
  role           Role        @default(EMPLOYEE)
  designation    String?
  employmentType EmploymentType @default(FULL_TIME)
  lifecycleStatus EmployeeLifecycleStatus @default(ACTIVE)
  baseSalary     Float       @default(0.0)
  hourlyRate     Float       @default(0.0)
  joiningDate    DateTime
  confirmationDate DateTime?
  exitDate       DateTime?
  timeZone       String?
  departmentId   Int?
  managerId      Int?
  workLocationId Int?
  
  department     Department? @relation(fields: [departmentId], references: [id])
  manager        User?       @relation("UserManager", fields: [managerId], references: [id])
  subordinates   User[]      @relation("UserManager")
  workLocation   WorkLocation? @relation(fields: [workLocationId], references: [id])
  projectAssignments UserProjectAssignment[]
  timesheets     Timesheet[]
  attendances    Attendance[]
  attendanceRegularizations AttendanceRegularization[] @relation("AttendanceRegularizationRequester")
  reviewedAttendanceRegularizations AttendanceRegularization[] @relation("AttendanceRegularizationReviewer")
  reviewedOvertimeAttendances Attendance[] @relation("AttendanceOvertimeReviewer")
  manualCorrectedAttendances Attendance[] @relation("AttendanceManualCorrector")
  attendanceAuditChanges AttendanceAuditLog[] @relation("AttendanceAuditChangedBy")
  loginActivities LoginActivity[]
  payrolls       Payroll[]
  leaves         Leave[]
  
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
}

model Department {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  description String?
  users       User[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model WorkLocation {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  code        String   @unique
  timeZone    String
  address     String?
  isActive    Boolean  @default(true)

  users       User[]
  attendancePolicies AttendancePolicy[]
  holidays    Holiday[]
  weeklyOffRules WeeklyOffRule[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model AttendancePolicy {
  id                     Int      @id @default(autoincrement())
  name                   String   @unique
  workLocationId         Int?
  standardWorkingHours   Float    @default(8)
  lateAfterMinutes       Int
  halfDayAfterMinutes    Int
  halfDayMinWorkingHours Float
  graceMinutes           Int      @default(0)
  overtimeAllowed        Boolean  @default(true)
  autoAbsentEnabled      Boolean  @default(false)
  effectiveFrom          DateTime
  effectiveTo            DateTime?
  isActive               Boolean  @default(true)

  workLocation           WorkLocation? @relation(fields: [workLocationId], references: [id])
  attendances            Attendance[]

  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  @@index([workLocationId, isActive])
}

model WeeklyOffRule {
  id                Int      @id @default(autoincrement())
  name              String
  workLocationId    Int?
  weekDay           Int
  weekNumberInMonth Int?
  isActive          Boolean  @default(true)
  effectiveFrom     DateTime
  effectiveTo       DateTime?

  workLocation      WorkLocation? @relation(fields: [workLocationId], references: [id])

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([workLocationId, isActive])
}

model Holiday {
  id          Int      @id @default(autoincrement())
  name        String
  holidayDate DateTime
  workLocationId Int?
  isOptional  Boolean  @default(false)
  description String?

  workLocation WorkLocation? @relation(fields: [workLocationId], references: [id])

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([holidayDate, workLocationId])
}

model Project {
  id          Int         @id @default(autoincrement())
  name        String
  description String?
  startDate   DateTime
  endDate     DateTime?
  projectAssignments UserProjectAssignment[]
  timesheets  Timesheet[]
  
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

model UserProjectAssignment {
  id          Int      @id @default(autoincrement())
  userId      Int
  projectId   Int
  assignedAt  DateTime @default(now())
  isActive    Boolean  @default(true)

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([userId, projectId])
  @@index([projectId])
  @@index([userId, isActive])
}

model Timesheet {
  id          Int              @id @default(autoincrement())
  userId      Int
  projectId   Int
  date        DateTime
  hours       Float
  status      TimesheetStatus  @default(PENDING)
  notes       String?
  
  user        User             @relation(fields: [userId], references: [id])
  project     Project          @relation(fields: [projectId], references: [id])
  
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
}

model Payroll {
  id          Int      @id @default(autoincrement())
  userId      Int
  month       Int
  year        Int
  baseAmount  Float
  hourlyAmount Float
  deductions  Float
  netPay      Float
  paymentDate DateTime?
  
  user        User     @relation(fields: [userId], references: [id])
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Leave {
  id          Int      @id @default(autoincrement())
  userId      Int
  type        String   // "SICK", "CASUAL", "PAID"
  startDate   DateTime
  endDate     DateTime
  status      String   @default("PENDING") // PENDING, APPROVED, REJECTED
  reason      String?
  
  user        User     @relation(fields: [userId], references: [id])
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Attendance {
  id                Int      @id @default(autoincrement())
  userId            Int
  attendanceDate    DateTime
  workMode          WorkMode
  source            AttendanceSource @default(WEB)
  policyId          Int?
  dayStatus         AttendanceDayStatus @default(PRESENT)
  remarks           String?
  lateMark          Boolean   @default(false)
  workingHours      Float?
  overtimeMinutes   Int       @default(0)
  overtimeStatus    AttendanceOvertimeStatus?
  overtimeReviewerId Int?
  overtimeReviewNotes String?
  overtimeReviewedAt DateTime?
  manualCorrectionReason String?
  manualCorrectedById Int?
  manualCorrectedAt  DateTime?
  checkInAt         DateTime
  checkOutAt        DateTime?
  checkInLatitude   Float?
  checkInLongitude  Float?
  checkOutLatitude  Float?
  checkOutLongitude Float?
  checkInIpAddress  String?
  checkOutIpAddress String?
  checkInUserAgent  String?
  checkOutUserAgent String?

  user              User     @relation(fields: [userId], references: [id])
  policy            AttendancePolicy? @relation(fields: [policyId], references: [id])
  overtimeReviewer  User?    @relation("AttendanceOvertimeReviewer", fields: [overtimeReviewerId], references: [id])
  manualCorrector   User?    @relation("AttendanceManualCorrector", fields: [manualCorrectedById], references: [id])
  auditLogs         AttendanceAuditLog[]

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([userId, attendanceDate])
  @@index([policyId])
}

model LoginActivity {
  id            Int      @id @default(autoincrement())
  userId        Int
  ipAddress     String?
  userAgent     String?
  latitude      Float?
  longitude     Float?
  locationLabel String?
  loggedInAt    DateTime @default(now())

  user          User     @relation(fields: [userId], references: [id])

  createdAt     DateTime @default(now())

  @@index([userId, loggedInAt])
}

model AttendanceRegularization {
  id                   Int                            @id @default(autoincrement())
  userId               Int
  attendanceDate       DateTime
  type                 AttendanceRegularizationType
  status               AttendanceRegularizationStatus @default(PENDING)
  reason               String
  requestedCheckInAt   DateTime?
  requestedCheckOutAt  DateTime?
  requestedWorkMode    WorkMode?
  reviewerId           Int?
  reviewNotes          String?
  reviewedAt           DateTime?

  user                 User                           @relation("AttendanceRegularizationRequester", fields: [userId], references: [id])
  reviewer             User?                          @relation("AttendanceRegularizationReviewer", fields: [reviewerId], references: [id])

  createdAt            DateTime                       @default(now())
  updatedAt            DateTime                       @updatedAt

  @@index([userId, attendanceDate])
  @@index([status, attendanceDate])
}

model AttendanceAuditLog {
  id              Int      @id @default(autoincrement())
  attendanceId    Int
  changedByUserId Int?
  changeType      String
  fieldName       String
  oldValue        String?
  newValue        String?
  changeReason    String?
  createdAt       DateTime @default(now())

  attendance      Attendance @relation(fields: [attendanceId], references: [id], onDelete: Cascade)
  changedByUser   User?      @relation("AttendanceAuditChangedBy", fields: [changedByUserId], references: [id])

  @@index([attendanceId, createdAt])
}

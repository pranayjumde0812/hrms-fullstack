generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ----------------------------------------------------
// ENUMS
// ----------------------------------------------------
enum Role {
  SUPER_ADMIN
  HR_MANAGER
  PROJECT_MANAGER
  EMPLOYEE
}

enum TimesheetStatus {
  PENDING
  APPROVED
  REJECTED
}

// ----------------------------------------------------
// ENTITIES
// ----------------------------------------------------
model User {
  id             String      @id @default(uuid())
  email          String      @unique
  password       String
  firstName      String
  lastName       String
  role           Role        @default(EMPLOYEE)
  baseSalary     Float       @default(0.0)
  hourlyRate     Float       @default(0.0)
  joiningDate    DateTime
  departmentId   String?
  
  department     Department? @relation(fields: [departmentId], references: [id])
  projects       Project[]   @relation("UserProjects")
  timesheets     Timesheet[]
  payrolls       Payroll[]
  leaves         Leave[]
  
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
}

model Department {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  users       User[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Project {
  id          String      @id @default(uuid())
  name        String
  description String?
  startDate   DateTime
  endDate     DateTime?
  users       User[]      @relation("UserProjects")
  timesheets  Timesheet[]
  
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

model Timesheet {
  id          String           @id @default(uuid())
  userId      String
  projectId   String
  date        DateTime
  hours       Float
  status      TimesheetStatus  @default(PENDING)
  notes       String?
  
  user        User             @relation(fields: [userId], references: [id])
  project     Project          @relation(fields: [projectId], references: [id])
  
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
}

model Payroll {
  id          String   @id @default(uuid())
  userId      String
  month       Int
  year        Int
  baseAmount  Float
  hourlyAmount Float
  deductions  Float
  netPay      Float
  paymentDate DateTime?
  
  user        User     @relation(fields: [userId], references: [id])
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Leave {
  id          String   @id @default(uuid())
  userId      String
  type        String   // "SICK", "CASUAL", "PAID"
  startDate   DateTime
  endDate     DateTime
  status      String   @default("PENDING") // PENDING, APPROVED, REJECTED
  reason      String?
  
  user        User     @relation(fields: [userId], references: [id])
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

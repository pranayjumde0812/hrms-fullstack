generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ----------------------------------------------------
// ENUMS
// ----------------------------------------------------
enum Role {
  SUPER_ADMIN
  HR_MANAGER
  PROJECT_MANAGER
  EMPLOYEE
}

enum TimesheetStatus {
  PENDING
  APPROVED
  REJECTED
}

enum WorkMode {
  WFH
  OFFICE
  OTHER
}

enum AttendanceRegularizationType {
  MISSED_CHECK_IN
  MISSED_CHECK_OUT
  FULL_CORRECTION
  WORK_MODE_CORRECTION
}

enum AttendanceRegularizationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum AttendanceDayStatus {
  PRESENT
  LATE
  HALF_DAY
}

enum AttendanceOvertimeStatus {
  PENDING
  APPROVED
  REJECTED
}

// ----------------------------------------------------
// ENTITIES
// ----------------------------------------------------
model User {
  id             Int         @id @default(autoincrement())
  email          String      @unique
  password       String
  firstName      String
  lastName       String
  role           Role        @default(EMPLOYEE)
  baseSalary     Float       @default(0.0)
  hourlyRate     Float       @default(0.0)
  joiningDate    DateTime
  departmentId   Int?
  managerId      Int?
  
  department     Department? @relation(fields: [departmentId], references: [id])
  manager        User?       @relation("UserManager", fields: [managerId], references: [id])
  subordinates   User[]      @relation("UserManager")
  projects       Project[]   @relation("UserProjects")
  timesheets     Timesheet[]
  attendances    Attendance[]
  attendanceRegularizations AttendanceRegularization[] @relation("AttendanceRegularizationRequester")
  reviewedAttendanceRegularizations AttendanceRegularization[] @relation("AttendanceRegularizationReviewer")
  reviewedOvertimeAttendances Attendance[] @relation("AttendanceOvertimeReviewer")
  loginActivities LoginActivity[]
  payrolls       Payroll[]
  leaves         Leave[]
  
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
}

model Department {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  description String?
  users       User[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Project {
  id          Int         @id @default(autoincrement())
  name        String
  description String?
  startDate   DateTime
  endDate     DateTime?
  users       User[]      @relation("UserProjects")
  timesheets  Timesheet[]
  
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

model Timesheet {
  id          Int              @id @default(autoincrement())
  userId      Int
  projectId   Int
  date        DateTime
  hours       Float
  status      TimesheetStatus  @default(PENDING)
  notes       String?
  
  user        User             @relation(fields: [userId], references: [id])
  project     Project          @relation(fields: [projectId], references: [id])
  
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
}

model Payroll {
  id          Int      @id @default(autoincrement())
  userId      Int
  month       Int
  year        Int
  baseAmount  Float
  hourlyAmount Float
  deductions  Float
  netPay      Float
  paymentDate DateTime?
  
  user        User     @relation(fields: [userId], references: [id])
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Leave {
  id          Int      @id @default(autoincrement())
  userId      Int
  type        String   // "SICK", "CASUAL", "PAID"
  startDate   DateTime
  endDate     DateTime
  status      String   @default("PENDING") // PENDING, APPROVED, REJECTED
  reason      String?
  
  user        User     @relation(fields: [userId], references: [id])
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Attendance {
  id                Int      @id @default(autoincrement())
  userId            Int
  attendanceDate    DateTime
  workMode          WorkMode
  dayStatus         AttendanceDayStatus @default(PRESENT)
  lateMark          Boolean   @default(false)
  workingHours      Float?
  overtimeMinutes   Int       @default(0)
  overtimeStatus    AttendanceOvertimeStatus?
  overtimeReviewerId Int?
  overtimeReviewNotes String?
  overtimeReviewedAt DateTime?
  checkInAt         DateTime
  checkOutAt        DateTime?
  checkInLatitude   Float?
  checkInLongitude  Float?
  checkOutLatitude  Float?
  checkOutLongitude Float?
  checkInIpAddress  String?
  checkOutIpAddress String?
  checkInUserAgent  String?
  checkOutUserAgent String?

  user              User     @relation(fields: [userId], references: [id])
  overtimeReviewer  User?    @relation("AttendanceOvertimeReviewer", fields: [overtimeReviewerId], references: [id])

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([userId, attendanceDate])
}

model LoginActivity {
  id            Int      @id @default(autoincrement())
  userId        Int
  ipAddress     String?
  userAgent     String?
  latitude      Float?
  longitude     Float?
  locationLabel String?
  loggedInAt    DateTime @default(now())

  user          User     @relation(fields: [userId], references: [id])

  createdAt     DateTime @default(now())

  @@index([userId, loggedInAt])
}

model AttendanceRegularization {
  id                   Int                            @id @default(autoincrement())
  userId               Int
  attendanceDate       DateTime
  type                 AttendanceRegularizationType
  status               AttendanceRegularizationStatus @default(PENDING)
  reason               String
  requestedCheckInAt   DateTime?
  requestedCheckOutAt  DateTime?
  requestedWorkMode    WorkMode?
  reviewerId           Int?
  reviewNotes          String?
  reviewedAt           DateTime?

  user                 User                           @relation("AttendanceRegularizationRequester", fields: [userId], references: [id])
  reviewer             User?                          @relation("AttendanceRegularizationReviewer", fields: [reviewerId], references: [id])

  createdAt            DateTime                       @default(now())
  updatedAt            DateTime                       @updatedAt

  @@index([userId, attendanceDate])
  @@index([status, attendanceDate])
}
